m = int(input("Введите стартовое количество организмов "))
p = int(input("Введите среднессуточное увеличение в процентах "))
n = int(input("Введите количество дней для размножения "))

daily_growth_factor = 1 + p / 100

current_population = m

for i in range(1, n + 1):
    print(i, current_population)
    current_population *= daily_growth_factor
